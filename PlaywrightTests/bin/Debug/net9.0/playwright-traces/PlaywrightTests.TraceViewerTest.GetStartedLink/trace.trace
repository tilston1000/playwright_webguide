s":"gh-text"},"Star"]],["A",{"class":"gh-count","href":"https://github.com/microsoft/playwright/stargazers","rel":"noopener noreferrer","target":"_blank","aria-label":"90k+ stargazers on GitHub","style":"display:block"},"90k+"]]]]],["MAIN",{},["SECTION",{"class":"pathCards_cPva"},["DIV",{"class":"container"},["DIV",{"class":"row"},["DIV",{"class":"col col--4 pathCard_fFQW"},["H3",{},"Playwright Test"],["P",{},"Full-featured test runner with auto-waiting, assertions, tracing, and parallelism across Chromium, Firefox, and WebKit."],["CODE",{"class":"installCode_lxde"},"npm init playwright@latest"],["DIV",{"class":"pathCardLink_NkwN"},["A",{"href":"/docs/intro"},"Testing documentation"]]],["DIV",{"class":"col col--4 pathCard_fFQW"},["H3",{},"Playwright CLI"],["P",{},"Token-efficient browser automation for coding agents like Claude Code and GitHub Copilot. Skill-based workflows without large context overhead."],["CODE",{"class":"installCode_lxde"},"npm i -g @playwright/cli@latest"],["DIV",{"class":"pathCardLink_NkwN"},["A",{"href":"/docs/getting-started-cli"},"CLI documentation"]]],["DIV",{"class":"col col--4 pathCard_fFQW"},["H3",{},"Playwright MCP"],["P",{},"Model Context Protocol server that gives AI agents full browser control through structured accessibility snapshots."],["CODE",{"class":"installCode_lxde"},"npx @playwright/mcp@latest"],["DIV",{"class":"pathCardLink_NkwN"},["A",{"href":"/docs/getting-started-mcp"},"MCP documentation"]]]]]],["SECTION",{"class":"featureSection_efmM featureSectionAlt_XlZb"},["DIV",{"class":"container"},["H2",{"class":"featureSectionTitle__Rac"},"Built for testing"],["DIV",{"class":"featureSectionContent_DG7g"},["DIV",{"class":"row"},["DIV",{"class":"col col--6"},["H4",{},"Auto-wait and web-first assertions"],["P",{},"Playwright waits for elements to be actionable before performing actions. Assertions automatically retry until conditions are met. No artificial timeouts, no flaky tests."],["H4",{},"Test isolation"],["P",{},"Each test gets a fresh browser context — equivalent to a brand new browser profile. Full isolation with near-zero overhead. Save authentication state once and reuse it across tests."]],["DIV",{"class":"col col--6"},["H4",{},"Resilient locators"],["P",{},"Find elements with selectors that mirror how users see the page:"," ",["CODE",{},"getByRole"],", ",["CODE",{},"getByLabel"],", ",["CODE",{},"getByPlaceholder"],","," ",["CODE",{},"getByTestId"],". No brittle CSS paths."],["H4",{},"Parallelism and sharding"],["P",{},"Tests run in parallel by default across all configured browsers. Shard across multiple machines for faster CI. Full cross-browser coverage on every commit."]]]]]],["SECTION",{"class":"featureSection_efmM"},["DIV",{"class":"container"},["H2",{"class":"featureSectionTitle__Rac"},"Built for AI agents"],["DIV",{"class":"featureSectionContent_DG7g"},["DIV",{"class":"row"},["DIV",{"class":"col col--6"},["H4",{},"Accessibility snapshots, not screenshots"],["P",{},"Agents interact with pages through structured accessibility trees — element roles, names, and refs. Deterministic and unambiguous, no vision models required."],["H4",{},"MCP server"],["P",{},"Drop-in ",["A",{"href":"https://modelcontextprotocol.io","target":"_blank","rel":"noreferrer noopener"},"Model Context Protocol"]," server for VS Code, Cursor, Claude Desktop, Windsurf, and any MCP client. Full browser control through standard tool calls."]],["DIV",{"class":"col col--6"},["H4",{},"CLI for coding agents"],["P",{},"Token-efficient command-line interface with installable skills. Purpose-built for Claude Code, GitHub Copilot, and similar coding agents that need to balance browser automation with large codebases."],["H4",{},"Session monitoring"],["P",{},"Visual dashboard with live screencast previews of all running browser sessions. Click any session to zoom in and take control."]]]]]],["SECTION",{"class":"featureSection_efmM featureSectionAlt_XlZb"},["DIV",{"class":"container"},["H2",{"class":"featureSectionTitle__Rac"},"Powerful tooling"],["DIV",{"class":"featureSectionContent_DG7g"},["DIV",{"class":"row"},["DIV",{"class":"col col--4"},["H4",{},["A",{"href":"docs/codegen"},"Test generator"]],["P",{},"Record your actions in the browser and Playwright writes the test code. Generate assertions from the recording toolbar. Pick locators by clicking on elements."]],["DIV",{"class":"col col--4"},["H4",{},["A",{"href":"docs/trace-viewer-intro"},"Trace Viewer"]],["P",{},"Full timeline of test execution with DOM snapshots, network requests, console logs, and screenshots at every step. Investigate failures without re-running."]],["DIV",{"class":"col col--4"},["H4",{},["A",{"href":"docs/getting-started-vscode"},"VS Code extension"]],["P",{},"Run, debug, and generate tests directly in the editor. Set breakpoints, live-inspect locators in the browser, and view full execution traces in the sidebar."]]]]]],["SECTION",{"class":"crossBrowser_o5jx"},["DIV",{"class":"container","style":"text-align:center"},["IMG",{"__playwright_current_src__":"https://playwright.dev/img/logos/Browsers.png","src":"img/logos/Browsers.png","width":"30%","alt":"Chromium, Firefox, WebKit"}],["P",{"class":"crossBrowserText_q4c8"},["B",{},"Any browser. Any platform."]," Chromium, Firefox, and WebKit on Linux, macOS, and Windows. Headless and headed. Also available for"," ",["A",{"href":"https://playwright.dev/python/docs/intro"},"Python"],","," ",["A",{"href":"https://playwright.dev/dotnet/docs/intro"},".NET"],", and"," ",["A",{"href":"https://playwright.dev/java/docs/intro"},"Java"],"."]]],["SECTION",{"class":"logosSection_gMWS"},["DIV",{"class":"container"},["DIV",{"class":"row"},["DIV",{"class":"col col--12 logosColumn_GJVT"},["H2",{},"Chosen by companies and open source projects"],["UL",{"class":"logosList_zAAF"},["LI",{},["A",{"href":"https://code.visualstudio.com","target":"_blank","rel":"noreferrer noopener"},["IMG",{"__playwright_current_src__":"https://playwright.dev/img/logos/VSCode.png","src":"img/logos/